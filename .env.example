# ============================================================
#  Variables de entorno del portafolio
#  Copia este archivo como .env.local y rellena los valores.
# ============================================================

# API key de Resend para el formulario de contacto (https://resend.com)
# Sin esto, el formulario muestra el fallback de WhatsApp/email.
RESEND_API_KEY=

# (Opcional) Remitente. Déjalo así hasta que verifiques tu dominio en Resend.
# CONTACT_FROM=Portafolio <onboarding@resend.dev>
